# Copy to `.env` and adjust if you want to override any default.
# `docker compose up` works with none of this present - every value below
# already has a matching `${VAR:-default}` fallback in docker-compose.yml.
# This file is the one place in the repo where these defaults are listed;
# nowhere else should a literal credential pair appear (secret-scanner
# hygiene - see README.md).

# --- Postgres ---
POSTGRES_DB=showcase
POSTGRES_USER=showcase
POSTGRES_PASSWORD=showcase

# --- Backend DB connection (mirrors the Postgres values above) ---
DB_HOST=postgres
DB_PORT=5432
DB_NAME=showcase
DB_USER=showcase
DB_PASSWORD=showcase

# --- Backend runtime ---
SPRING_PROFILES_ACTIVE=docker
# Must match the Keycloak `iss` claim - see README.md, "Keycloak issuer /
# hostname", before changing this.
KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/showcase

# --- Keycloak admin console (quay.io/keycloak/keycloak) ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- Demo application users, seeded by the keycloak-init compose service ---
# demo  -> realm role: user
# admin -> realm roles: user, admin
DEMO_USER_PASSWORD=demo1234
DEMO_ADMIN_PASSWORD=admin1234
